---
interface Props {
  class?: string;
}

const { class: className = "" } = Astro.props;
---

<svg
  class:list={["copy-icon", className]}
  viewBox="0 0 15 16"
  xmlns="http://www.w3.org/2000/svg"
  fill="currentColor"
  stroke="none"
  aria-hidden="true"
>
  <path
    d="M14.5 2A1.5 1.5.0 0116 3.5v12A1.5 1.5.0 0114.5 17h-9A1.5 1.5.0 014 15.5v-12A1.5 1.5.0 015.5 2h9zm-1 2.5h-7v10h7v-10z"
    fill-rule="nonzero"></path>
  <path
    d="M10.5-2A1.5 1.5.0 0112-.5v1H2.5V13h-1A1.5 1.5.0 010 11.5v-12A1.5 1.5.0 011.5-2h9z"
    fill-rule="nonzero"></path>
</svg>

<style>
  /* :where() keeps specificity at 0 so consumer classes (e.g. h-4) override. */
  :where(.copy-icon) {
    display: inline-block;
    height: var(--font-x-height);
    width: auto;
    overflow: visible;
    vertical-align: baseline;
  }
</style>

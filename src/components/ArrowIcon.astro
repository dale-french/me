---
interface Props {
  class?: string;
}

const { class: className = "" } = Astro.props;
---

<svg
  class:list={["arrow-icon", className]}
  viewBox="0 0 24 20"
  xmlns="http://www.w3.org/2000/svg"
  fill="none"
  stroke="currentColor"
  aria-hidden="true"
>
  <path d="M0 10h24M14 20l10-10L14 0" vector-effect="non-scaling-stroke"></path>
</svg>

<style>
  /* :where() keeps specificity at 0 so consumer classes (e.g. h-4) override. */
  :where(.arrow-icon) {
    display: inline-block;
    height: var(--font-x-height);
    width: auto;
    overflow: visible;
    stroke-width: var(--icon-stroke);
    vertical-align: baseline;
  }
</style>

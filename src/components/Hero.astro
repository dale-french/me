---
import Logo from "./Logo.astro";
import { introSegments } from "../data/intro";
---

<section class="hero depth-layer">
  <a href="/" class="brand" aria-label="Home">
    <Logo
      class="h-14 w-14 sm:h-16 sm:w-16 lg:h-[76px] lg:w-[76px]"
      bg="black"
      fg="white"
    />
  </a>

  <h1 class="hero-text">
    <noscript>Hi there. I'm Dale French.</noscript>
    {
      introSegments.map((seg, i) => (
        <>
          {i > 0 && " "}
          <span class="typed" id={`seg-${seg.id}`} />
        </>
      ))
    }
  </h1>

  {
    introSegments.map((seg) => (
      <ul id={`seg-${seg.id}--strings`} class="typed-strings">
        {seg.strings.map((s) => (
          <li set:html={s} />
        ))}
      </ul>
    ))
  }
</section>

<script>
  import { startTypedSequence } from "../scripts/typed-sequence";

  const host = document.querySelector<HTMLElement>(".hero");
  if (host) startTypedSequence(host);
</script>

<style>
  .hero {
    --depth: -2;
    min-height: 100dvh;
    display: grid;
    grid-template-rows: max-content 1fr;
    row-gap: clamp(2rem, 6vw, 4rem);
    padding: clamp(2.5rem, 5vw, 5rem) clamp(1.5rem, 5vw, 6rem);
    background-color: var(--color-bg);
    transition: opacity 1s ease-out;
  }

  .hero.typed--background {
    opacity: 0.333;
  }

  .brand {
    display: inline-flex;
    width: max-content;
    border-radius: 0.4rem;
    color: var(--color-fg);
  }

  .brand:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: var(--link-outline);
  }

  .hero-text {
    align-self: start;
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.75rem, 5.5vw, 4.5rem);
    line-height: 1.15;
    letter-spacing: -0.01em;
    color: var(--color-fg);
    cursor: default;
    pointer-events: none;
    user-select: all;
  }

  .hero-text > * {
    pointer-events: auto;
  }

  /* Hidden until typed.js applies its own clip styles. */
  .typed-strings {
    display: none;
  }

  .typed {
    color: var(--color-fg);
    opacity: var(--alpha-faded);
    transition:
      color 375ms ease-out,
      opacity 375ms ease-out;
  }

  /* The most-recently-typed and currently-typing segments stay full color. */
  .typed--fresh,
  .typed--active {
    opacity: 1;
  }

  /* Emoji span: match font, sit on the line, fade with parent. */
  .typed span {
    color: initial;
    font-family:
      "Twemoji Mozilla", "Apple Color Emoji", "Segoe UI Emoji", "Segoe UI Symbol",
      "Noto Color Emoji", sans-serif;
    line-height: 0;
    display: inline-block;
    transform: translate(-0.05em, 0.05em);
  }

  /* Blinking caret on the active segment, in the accent color. */
  .typed--active::after {
    content: "|";
    color: var(--color-accent);
    margin-left: 0.02em;
    transform: translateY(-0.04em);
    display: inline-block;
  }

  .typed--active:not(.typed--typing)::after {
    animation: caret-blink 750ms linear infinite;
  }

  @keyframes caret-blink {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0;
    }
  }

  .hero.typed--background .typed--active::after {
    animation-play-state: paused;
    opacity: 0;
  }
</style>

---
import Logo from "./Logo.astro";
import { introSegments } from "../data/intro";
---

<div class="hero-stage depth-layer min-h-dvh">
  <section
    class="hero gap-y-16 px-12 pt-12 pb-4 sm:gap-y-20 sm:px-48 sm:pt-16 sm:pb-6"
  >
    <a href="/" class="brand" aria-label="Home">
      <Logo bg="black" fg="white" size={72} />
    </a>

    <h1 class="hero-text text-4xl sm:text-5xl md:text-7xl">
      <noscript>Hi there. I'm Dale French.</noscript>
      {
        introSegments.map((seg, i) => (
          <>
            {i > 0 && " "}
            <span class="typed" id={`seg-${seg.id}`} />
          </>
        ))
      }
    </h1>

    {
      introSegments.map((seg) => (
        <ul id={`seg-${seg.id}--strings`} class="typed-strings">
          {seg.strings.map((s) => (
            <li set:html={s} />
          ))}
        </ul>
      ))
    }
  </section>
</div>

<script>
  import { startTypedSequence } from "../scripts/typed-sequence";

  const host = document.querySelector<HTMLElement>(".hero");
  if (host) startTypedSequence(host);
</script>

<style>
  .hero-stage {
    --depth: -2;
    background-color: var(--color-bg);
  }

  .hero {
    display: flex;
    flex-direction: column;
    transition: opacity 1s ease-out;
  }

  .hero.typed--background {
    opacity: 0.333;
  }

  .brand {
    display: inline-flex;
    width: max-content;
    border-radius: var(--radius-link);
    color: var(--color-fg);
  }

  .brand:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: var(--link-outline);
  }

  .hero-text {
    align-self: start;
    font-family: var(--font-display);
    line-height: 1;
    letter-spacing: 0;
    font-weight: 500;
    color: var(--color-fg);
    cursor: default;
    pointer-events: none;
    user-select: all;
  }

  .hero-text > * {
    pointer-events: auto;
  }

  /* Hidden until typed.js applies its own clip styles. */
  .typed-strings {
    display: none;
  }

  .typed {
    color: var(--color-fg);
    opacity: 0.2;
    transition:
      color 375ms ease-out,
      opacity 375ms ease-out;
  }

  /* Most-recently-typed and currently-typing segments stay full color. */
  .typed--fresh,
  .typed--active {
    opacity: 1;
  }

  /* Emoji span: match font, sit on the line, fade with parent. */
  .typed span {
    color: initial;
    font-family:
      "Twemoji Mozilla", "Apple Color Emoji", "Segoe UI Emoji",
      "Segoe UI Symbol", "Noto Color Emoji", sans-serif;
    line-height: 0;
    display: inline-block;
    transform: translate(-0.05em, 0.05em);
  }

  /* Blinking caret on the active segment, in the accent color. */
  .typed--active::after {
    content: "|";
    color: var(--color-accent);
    margin-left: 0.02em;
    transform: translateY(-0.04em);
    display: inline-block;
  }

  .typed--active:not(.typed--typing)::after {
    animation: caret-blink 750ms linear infinite;
  }

  @keyframes caret-blink {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0;
    }
  }

  .hero.typed--background .typed--active::after {
    animation-play-state: paused;
    opacity: 0;
  }
</style>

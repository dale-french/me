---
import Logo from "./Logo.astro";
import { introSegments } from "../data/intro";

const staticIntro =
  "Hi there. My name is Dale French, and I’m a frontend engineer and engineering manager based in Amsterdam.";
---

<div class="hero-stage depth-layer min-h-dvh">
  <section
    class="hero px-page-x pt-page-y-md pb-4 sm:pb-6"
    data-static-intro={staticIntro}
  >
    <a href="/" class="brand" aria-label="Home">
      <Logo class="w-(--logo-size) h-(--logo-size)" bg="black" fg="white" />
    </a>

    <h1 class="hero-text" aria-label={staticIntro}>
      <noscript>{staticIntro}</noscript>
      <span class="hero-text-typing" aria-hidden="true">
        <Fragment
          set:html={introSegments
            .map((seg) => `<span class="typed" id="seg-${seg.id}"></span>`)
            .join(" ")}
        />
      </span>
    </h1>
  </section>
</div>

<script>
  import { startTypedSequence } from "../scripts/typed-sequence";

  const FOOTER_PAUSE_RATIO = 0.5;

  const host = document.querySelector<HTMLElement>(".hero");
  if (host) {
    const reduced = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;
    if (reduced) {
      const heroText = host.querySelector<HTMLElement>(".hero-text");
      const fallback = host.dataset.staticIntro ?? "";
      if (heroText && fallback) heroText.textContent = fallback;
    } else {
      const controller = startTypedSequence(host);
      const footer = document.querySelector<HTMLElement>(".site-footer");
      if (footer) {
        let pausedByFooter = false;
        const observer = new IntersectionObserver(
          (entries) => {
            // Entries batch oldest → newest; only the last reflects the
            // current state.
            const entry = entries[entries.length - 1];
            const occluded = entry.intersectionRatio >= FOOTER_PAUSE_RATIO;
            if (occluded && !pausedByFooter) {
              pausedByFooter = true;
              host.classList.add("typed--background");
              controller.pause();
            } else if (!occluded && pausedByFooter) {
              pausedByFooter = false;
              host.classList.remove("typed--background");
              controller.resume();
            }
          },
          { threshold: [0, FOOTER_PAUSE_RATIO, 1] },
        );
        observer.observe(footer);
      }
    }
  }
</script>

<style>
  .hero-stage {
    --depth: -2;
    background-color: var(--color-bg);
  }

  .hero {
    display: flex;
    flex-direction: column;
    row-gap: var(--hero-gap-y);
  }

  .brand {
    display: inline-flex;
    width: max-content;
    border-radius: var(--radius-link);
    color: var(--color-fg);
  }

  .hero-text {
    align-self: start;
    font-family: var(--font-display);
    font-size: var(--hero-text);
    line-height: 1;
    letter-spacing: 0;
    font-weight: 500;
    color: var(--color-fg);
    cursor: default;
    pointer-events: none;
    user-select: all;
    /* Reserve three lines of capacity so the layout doesn't jump as short
       and long strings cycle through. Most strings fit; very long ones
       still expand below this floor. */
    min-height: 3em;
    /* Intentionally NOT `text-wrap: pretty` — pretty re-balances lines as
       content grows, which causes the final character of a typing run to
       trigger a visible re-wrap. */
  }

  .hero-text > * {
    pointer-events: auto;
  }

  .hero-text-typing {
    /* Wrapper exists only to scope `aria-hidden` over the dynamic content.
       Inline-flow so the segments share the h1's line box. */
    display: inline;
  }

  :global(.typed) {
    color: var(--color-fg);
    opacity: 0.2;
  }

  @media (prefers-reduced-motion: no-preference) {
    :global(.typed) {
      transition:
        color 375ms ease-out,
        opacity 375ms ease-out;
    }
  }

  :global(.typed--active) {
    opacity: 1;
  }

  /* Paused state: every segment fades to the same uniform light grey,
     including the active one. Lighter than the resting dim so the whole
     line reads as "at rest" rather than "this part is more important." */
  .hero:global(.typed--background) :global(.typed),
  .hero:global(.typed--background) :global(.typed--active) {
    opacity: 0.12;
    transition:
      color 500ms ease-out,
      opacity 500ms ease-out;
  }

  /* Emoji-wrapping spans within a typed segment. line-height: 0 keeps the
     emoji from inflating the baseline; the translate fine-tunes optical
     alignment with the surrounding glyphs. */
  :global(.typed span) {
    color: initial;
    font-family:
      "Twemoji Mozilla", "Apple Color Emoji", "Segoe UI Emoji",
      "Segoe UI Symbol", "Noto Color Emoji", sans-serif;
    line-height: 0;
    display: inline-block;
    transform: translate(-0.05em, 0.05em);
  }

  /* Caret. A sized pseudo-element rather than the `|` glyph, so its width
     and height aren't at the mercy of whichever font is serving the
     heading. The negative right margin makes the caret render *over* the
     trailing inter-segment space rather than push subsequent content
     rightward — so when the caret leaves a segment (active moves), nothing
     shifts. */
  :global(.typed--active::after) {
    content: "";
    display: inline-block;
    width: 0.08em;
    height: 0.85em;
    margin-left: 0.06em;
    margin-right: -0.14em;
    vertical-align: -0.05em;
    background-color: var(--color-accent);
  }

  :global(.typed--active:not(.typed--typing)::after) {
    animation: hero-caret-blink 750ms linear infinite;
  }

  @keyframes hero-caret-blink {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0;
    }
  }

  .hero:global(.typed--background) :global(.typed--active::after) {
    animation-play-state: paused;
    opacity: 0;
  }
</style>

---
import Logo from "./Logo.astro";
import { introSegments } from "../data/intro";
---

<div class="hero-stage depth-layer min-h-dvh">
  <section
    class="hero px-page-x pt-page-y-md pb-4 sm:pb-6"
  >
    <a href="/" class="brand" aria-label="Home">
      <Logo class="w-(--logo-size) h-(--logo-size)" bg="black" fg="white" />
    </a>

    <h1 class="hero-text">
      <noscript
        >Hi there. My name is Dale French, and I’m a frontend engineer and
        engineering manager based in Amsterdam.</noscript
      >
      <Fragment
        set:html={introSegments
          .map((seg) => `<span class="typed" id="seg-${seg.id}"></span>`)
          .join(" ")}
      />
    </h1>

    {
      introSegments.map((seg) => (
        <ul id={`seg-${seg.id}--strings`} class="typed-strings">
          {seg.strings.map((s) => (
            <li set:html={s} />
          ))}
        </ul>
      ))
    }
  </section>
</div>

<script>
  import { startTypedSequence } from "../scripts/typed-sequence";

  const host = document.querySelector<HTMLElement>(".hero");
  if (host) startTypedSequence(host, { pauseThreshold: 0.666 });
</script>

<style>
  .hero-stage {
    --depth: -2;
    background-color: var(--color-bg);
  }

  .hero {
    display: flex;
    flex-direction: column;
    row-gap: var(--hero-gap-y);
    transition: opacity 1s ease-out;
  }

  .hero.typed--background {
    opacity: 0.333;
  }

  .brand {
    display: inline-flex;
    width: max-content;
    border-radius: var(--radius-link);
    color: var(--color-fg);
  }

  .hero-text {
    align-self: start;
    font-family: var(--font-display);
    font-size: var(--hero-text);
    line-height: 1;
    letter-spacing: 0;
    font-weight: 500;
    color: var(--color-fg);
    cursor: default;
    pointer-events: none;
    user-select: all;
  }

  .hero-text > * {
    pointer-events: auto;
  }

  :global(.typed-strings) {
    display: none;
  }

  :global(.typed) {
    color: var(--color-fg);
    opacity: 0.2;
    transition:
      color 375ms ease-out,
      opacity 375ms ease-out;
  }

  :global(.typed--active) {
    opacity: 1;
  }

  :global(.typed span) {
    color: initial;
    font-family:
      "Twemoji Mozilla", "Apple Color Emoji", "Segoe UI Emoji",
      "Segoe UI Symbol", "Noto Color Emoji", sans-serif;
    line-height: 0;
    display: inline-block;
    transform: translate(-0.05em, 0.05em);
  }

  :global(.typed--active::after) {
    content: "|";
    color: var(--color-accent);
    margin-left: 0.02em;
    transform: translateY(-0.04em);
    display: inline-block;
  }

  :global(.typed--active:not(.typed--typing)::after) {
    animation: caret-blink 750ms linear infinite;
  }

  @keyframes caret-blink {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0;
    }
  }

  .hero:global(.typed--background) :global(.typed--active::after) {
    animation-play-state: paused;
    opacity: 0;
  }
</style>

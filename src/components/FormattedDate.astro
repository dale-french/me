---
interface Props {
  date: Date;
  class?: string;
}

const { date, class: className } = Astro.props;
---

<time datetime={date.toISOString()} class:list={["formatted-date", className]}>
  {
    date.toLocaleDateString("en-us", {
      year: "numeric",
      month: "short",
      day: "numeric",
    })
  }
</time>

<style>
  .formatted-date {
    font-size: 0.875rem;
    color: var(--color-muted);
  }
</style>

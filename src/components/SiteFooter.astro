---
import ArrowIcon from "./ArrowIcon.astro";
import CopyIcon from "./CopyIcon.astro";
import Logo from "./Logo.astro";
import { contactLinks } from "../data/links";
import { footerNotes } from "../data/notes";

const year = new Date().getFullYear();
---

<footer class="site-footer depth-layer -mt-[30vh] px-12 py-4 sm:px-48 sm:py-12">
  <ul class="contact-list">
    {
      contactLinks.map((link) => (
        <li>
          <a
            href={link.href}
            rel={link.external ? "me noopener" : "me"}
            target={link.external ? "_blank" : undefined}
            class="contact-link"
          >
            {link.label}&#8197;
            <span>
              <ArrowIcon />
            </span>
          </a>
          {link.copy && (
            <p
              class="copy-link"
              data-copy={link.copy}
              role="button"
              tabindex="0"
              aria-label={`Copy ${link.copy}`}
            >
              {link.copy}
              <CopyIcon class="copy-link-icon" />
            </p>
          )}
        </li>
      ))
    }
  </ul>

  <section class="bookend">
    <div class="year-block">
      <a href="/" class="home-link" aria-label="Home">
        <Logo bg="black" fg="white" size={32} />
      </a>
      <p class="year">{year}</p>
    </div>
    <ul class="notes" data-notes>
      {footerNotes.map((n) => <li set:html={n} />)}
    </ul>
  </section>
</footer>

<script>
  import { mountClipboardCopy } from "../scripts/clipboard-copy";
  import { mountRandomNote } from "../scripts/random-note";

  document
    .querySelectorAll<HTMLElement>(".copy-link")
    .forEach(mountClipboardCopy);

  const bookend = document.querySelector<HTMLElement>(".bookend");
  const notes = document.querySelector<HTMLUListElement>("[data-notes]");
  if (bookend && notes) mountRandomNote(bookend, notes);
</script>

<style>
  .site-footer {
    --depth: 0.25;
    position: relative;
    display: flex;
    flex-direction: column;
    row-gap: 33vh;
    min-height: 38.2vh;
    background-color: var(--color-surface-faded);
    backdrop-filter: blur(0.42rem);
    -webkit-backdrop-filter: blur(0.42rem);
    font-family: var(--font-display);
    font-weight: 500;
    color: var(--color-fg);
  }

  .contact-list {
    font-size: 2rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .contact-list li {
    position: relative;
  }

  /* Extra breathing room below the first contact (Email). */
  .contact-list li:first-child {
    margin-bottom: 0.5em;
  }

  .contact-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-inline: calc(-1 * var(--link-enlargement));
    padding-inline: var(--link-enlargement);
    border-radius: var(--radius-link);
    white-space: nowrap;
    cursor: pointer;
    -webkit-tap-highlight-color: rgb(0 0 0 / 0.066);
  }

  .contact-link:active {
    background-color: rgb(0 0 0 / 0.066);
  }

  .contact-link:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: var(--link-outline);
  }

  .copy-link {
    display: none;
    padding-inline: var(--link-enlargement);
    margin-inline-start: calc(-1 * var(--link-enlargement) + 1rem);
    border-radius: var(--radius-link);
    color: var(--color-faded);
    cursor: copy;
    opacity: 0;
    visibility: hidden;
    transition:
      opacity 200ms ease-in,
      visibility 0s linear 200ms;
  }

  @media (min-width: 48rem) {
    .copy-link {
      display: inline-block;
    }
  }

  .contact-link:hover ~ .copy-link,
  .contact-link:focus-visible ~ .copy-link,
  .copy-link:hover,
  .copy-link:focus-visible {
    opacity: 1;
    visibility: visible;
    transition-delay: 0s, 0s;
  }

  .copy-link:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: var(--link-outline);
  }

  .copy-link-icon {
    margin-left: 0.5em;
  }

  .bookend {
    font-size: 1.5rem;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
  }

  .year-block {
    display: flex;
    align-items: center;
    gap: 0.5em;
  }

  .home-link {
    display: inline-flex;
    margin: calc(-1 * var(--link-enlargement));
    padding: var(--link-enlargement);
    border-radius: var(--radius-link);
    color: var(--color-fg);
    transition: transform 150ms ease-out;
  }

  .home-link:active {
    transform: scale(0.9);
  }

  .home-link:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: var(--link-outline);
  }

  .notes {
    text-align: right;
  }

  .notes li {
    display: none;
  }

  .notes li.is-visible {
    display: block;
  }
</style>

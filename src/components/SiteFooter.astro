---
import ArrowIcon from "./ArrowIcon.astro";
import CopyIcon from "./CopyIcon.astro";
import Logo from "./Logo.astro";
import { contactLinks } from "../data/links";
import { footerNotes } from "../data/notes";

const year = new Date().getFullYear();
---

<footer
  class="site-footer depth-layer mt-[-20vh] px-page-x py-page-y-sm sm:py-page-y-md"
>
  <ul class="contact-list">
    {
      contactLinks.map((link) => (
        <li>
          <a
            href={link.href}
            rel={link.external ? "me noopener" : "me"}
            target={link.external ? "_blank" : undefined}
            class="contact-link"
          >
            {link.label}&#8197;
            <span>
              <ArrowIcon />
            </span>
          </a>
          {link.copy && (
            <button
              type="button"
              class="copy-link"
              data-copy={link.copy}
              aria-label={`Copy ${link.copy}`}
            >
              <span data-copy-label>{link.copy}</span>
              {/* Tailwind rather than a scoped class: scoped styles can't
                  reach the svg inside the child component. */}
              <CopyIcon class="ml-[0.5em]" />
            </button>
          )}
        </li>
      ))
    }
  </ul>

  <section class="bookend">
    <div class="year-block">
      <a href="/" class="home-link" aria-label="Home">
        <Logo bg="black" fg="white" size={32} />
      </a>
      <p class="year">{year}</p>
    </div>
    <ul class="notes" data-notes>
      {footerNotes.map((n) => <li set:html={n} />)}
    </ul>
  </section>
  <span class="sr-only" aria-live="polite" data-copy-status></span>
</footer>

<script>
  import { mountClipboardCopy } from "../scripts/clipboard-copy";
  import { mountRandomNote } from "../scripts/random-note";

  document
    .querySelectorAll<HTMLButtonElement>("button.copy-link")
    .forEach(mountClipboardCopy);

  const bookend = document.querySelector<HTMLElement>(".bookend");
  const notes = document.querySelector<HTMLUListElement>("[data-notes]");
  if (bookend && notes) mountRandomNote(bookend, notes);

  // The server-rendered year is baked in at build time; correct it client-side
  // so a stale deploy doesn't show last year forever.
  const yearEl = document.querySelector<HTMLElement>(".year");
  if (yearEl) yearEl.textContent = String(new Date().getFullYear());
</script>

<style>
  .site-footer {
    --depth: 0.25;
    position: relative;
    display: flex;
    flex-direction: column;
    row-gap: clamp(6rem, 25vh, 18rem);
    min-height: 38.2vh;
    font-family: var(--font-display);
    font-weight: 500;
    color: var(--color-fg);
  }

  .site-footer::before {
    content: "";
    position: absolute;
    inset: 0;
    background-color: var(--color-surface-faded);
    backdrop-filter: blur(0.42rem);
    -webkit-backdrop-filter: blur(0.42rem);
    mask-image: linear-gradient(
      to bottom,
      transparent 0,
      black clamp(2rem, 8vh, 6rem)
    );
    -webkit-mask-image: linear-gradient(
      to bottom,
      transparent 0,
      black clamp(2rem, 8vh, 6rem)
    );
    pointer-events: none;
  }

  .site-footer > :not(.sr-only) {
    position: relative;
  }

  .contact-list {
    font-size: clamp(1.5rem, 2.5vw + 0.75rem, 2rem);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .contact-list li {
    position: relative;
  }

  /* Email is the primary contact; set it apart from the social links. */
  .contact-list li:first-child {
    margin-bottom: 0.5em;
  }

  .contact-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    /* Enlarge on both axes (like .home-link): the enlarged box is what the
       :active wash and focus ring wrap, so the text gets breathing room
       inside them instead of the pill hugging the glyphs. */
    margin: calc(-1 * var(--link-enlargement));
    padding: var(--link-enlargement);
    border-radius: var(--radius-link);
    white-space: nowrap;
    cursor: pointer;
    -webkit-tap-highlight-color: rgb(0 0 0 / 0.066);
  }

  .contact-link:active {
    background-color: rgb(0 0 0 / 0.066);
  }

  .copy-link {
    display: inline-block;
    padding-block: var(--link-enlargement);
    margin-block: calc(-1 * var(--link-enlargement));
    padding-inline: var(--link-enlargement);
    margin-inline-start: calc(-1 * var(--link-enlargement) + 1rem);
    border: 0;
    border-radius: var(--radius-link);
    background: transparent;
    font: inherit;
    color: var(--color-faded);
    text-align: start;
    cursor: copy;
  }

  .copy-link.is-copied {
    color: var(--color-accent);
    cursor: default;
  }

  /* Touch devices: the Email link already opens the mail app, so the
     copyable address is hover-workflow sugar — don't show it at all. */
  @media (hover: none) {
    .copy-link {
      display: none;
    }
  }

  @media (hover: hover) {
    /* Hidden via opacity alone — `visibility: hidden` would drop the button
       from the tab order, making it unreachable when Shift+Tabbing backward
       (its own :focus-visible reveal can't fire before it can be focused). */
    .copy-link {
      opacity: 0;
      transition: opacity 200ms ease-in;
    }

    .contact-link:hover ~ .copy-link,
    .contact-link:focus-visible ~ .copy-link,
    .copy-link:hover,
    .copy-link:focus-visible {
      opacity: 1;
    }
  }

  .bookend {
    font-size: clamp(1.125rem, 1.5vw + 0.5rem, 1.5rem);
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
  }

  .year-block {
    display: flex;
    align-items: center;
    gap: 0.5em;
  }

  .home-link {
    display: inline-flex;
    margin: calc(-1 * var(--link-enlargement));
    padding: var(--link-enlargement);
    border-radius: var(--radius-link);
    color: var(--color-fg);
    transition: transform 150ms ease-out;
  }

  .home-link:active {
    transform: scale(0.9);
  }

  .notes {
    flex: 1 1 auto;
    text-align: right;
  }

  .notes li {
    display: none;
  }

  .notes li.is-visible {
    display: block;
  }
</style>

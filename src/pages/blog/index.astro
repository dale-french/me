---
import { getCollection } from "astro:content";
import FormattedDate from "../../components/FormattedDate.astro";
import Header from "../../components/Header.astro";
import Layout from "../../layouts/Layout.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../../consts";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<Layout title={SITE_TITLE} description={SITE_DESCRIPTION}>
  <div class="min-h-dvh">
    <Header />
    <main class="px-12 pt-16 pb-24 sm:px-48 sm:pt-24">
      <header class="mb-12 max-w-[64rem] sm:mb-16">
        <h1 class="page-title">Writing</h1>
        <p class="page-dek">A running notebook on building software and the craft.</p>
      </header>

      <ul class="post-list max-w-[64rem]">
        {
          posts.map((post) => (
            <li>
              <a href={`/blog/${post.id}/`} class="post-row">
                <FormattedDate date={post.data.pubDate} class="post-row__date" />
                <div class="post-row__body">
                  <h2 class="post-row__title">
                    {post.data.title}
                    <svg
                      class="post-row__arrow"
                      viewBox="0 0 24 24"
                      aria-hidden="true"
                    >
                      <path
                        d="M5 12h14M13 5l7 7-7 7"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                    </svg>
                  </h2>
                  {post.data.description && (
                    <p class="post-row__desc">{post.data.description}</p>
                  )}
                </div>
              </a>
            </li>
          ))
        }
      </ul>
    </main>
  </div>
  <SiteFooter flat />
</Layout>

<style>
  .page-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(2.5rem, 5.5vw, 4.5rem);
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--color-fg);
    margin: 0;
  }

  .page-dek {
    margin: 1.25rem 0 0;
    font-family: var(--font-sans);
    font-size: clamp(1.125rem, 1.75vw, 1.5rem);
    line-height: 1.45;
    color: var(--color-muted);
    text-wrap: pretty;
  }

  .post-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
  }

  .post-list li + li {
    border-top: 1px solid color-mix(in srgb, var(--color-fg) 10%, transparent);
  }

  .post-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.5rem;
    padding: 1.75rem 0.75rem;
    margin-inline: -0.75rem;
    border-radius: var(--radius-link);
    color: var(--color-fg);
    text-decoration: none;
    transition: background-color 220ms ease;
  }

  @media (min-width: 48rem) {
    .post-row {
      grid-template-columns: 8rem 1fr;
      gap: 2rem;
      align-items: baseline;
      padding: 2.5rem 0.75rem;
    }
  }

  .post-row :global(.post-row__date) {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-muted);
    align-self: start;
    padding-top: 0.4rem;
  }

  .post-row__body {
    min-width: 0;
  }

  .post-row__title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.625rem, 2.6vw, 2.25rem);
    line-height: 1.15;
    letter-spacing: -0.015em;
    color: var(--color-fg);
    margin: 0;
    text-wrap: pretty;
    transition: color 220ms ease;
  }

  .post-row__arrow {
    display: inline-block;
    width: 0.6em;
    height: 0.6em;
    margin-left: 0.4em;
    color: var(--color-accent);
    opacity: 0;
    transform: translateX(-0.25em);
    transition:
      opacity 220ms ease,
      transform 220ms ease;
  }

  .post-row__desc {
    margin: 0.5rem 0 0;
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    line-height: 1.5;
    color: var(--color-muted);
    text-wrap: pretty;
    max-width: 38rem;
  }

  .post-row:hover,
  .post-row:focus-visible {
    background-color: color-mix(in srgb, var(--color-accent) 5%, transparent);
  }

  .post-row:hover .post-row__title,
  .post-row:focus-visible .post-row__title {
    color: var(--color-accent);
  }

  .post-row:hover .post-row__arrow,
  .post-row:focus-visible .post-row__arrow {
    opacity: 1;
    transform: translateX(0);
  }

  .post-row:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: var(--link-outline);
  }
</style>
